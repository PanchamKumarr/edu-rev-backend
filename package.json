{
  "name": "edu-rev-backend",
  "version": "1.0.0",
  "description": "EDU-REV Backend API with Express.js",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--use-system-ca tsx watch src/index.ts",
